{
    "manifest_version": 3,
    "name": "E. W. Password Generator",
    "short_name": "ewpassext",
    "description": "Extension that allows stateless, website-specific password derivation based on a single master password",
    "version": "1.4.1",
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png"
    },
    "key": "pjgkihajanbcehlidbefiinjdcogioeb",
    "permissions": [
        "activeTab",
        "alarms",
        "scripting",
        "storage",
        "webNavigation"
    ],
    "optional_permissions": [
        "clipboardRead"
    ],
    "action": {
         "title": "E. W. Password Generator - Chromium Extension Edition",
         "default_popup": "index.html"
    },
    "background": {
        "service_worker": "serviceworker.js",
        "type": "module"
    },
    "host_permissions": [
        "https://*/*"
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "{6d1f30b1-2f6d-48f9-a01a-c32a0c27d12d}",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    }
}
