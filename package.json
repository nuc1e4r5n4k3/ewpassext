{
    "name": "passext",
    "version": "1.4.0",
    "private": true,
    "dependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/chrome": "^0.2.2",
        "@types/firefox-webext-browser": "^143.0.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^26.1.0",
        "@types/node-sass": "^4.11.2",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/react-numeric-input": "^2.2.4",
        "@types/sha256": "^0.2.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-numeric-input": "^2.2.3",
        "react-select": "^5.3.0",
        "sass": "^1.101.0",
        "sha256": "^0.2.0",
        "typescript": "^6.0.3",
        "web-vitals": "^5.3.0"
    },
    "scripts": {
        "start": "vite",
        "typecheck": "tsc --noEmit",
        "build": "tsc --noEmit && vite build && vite build --config vite.scriptinjections.config.ts",
        "build-firefox": "$npm_execpath build && patch -d build < firefox/manifest.json.patch && cd build && zip -r {6d1f30b1-2f6d-48f9-a01a-c32a0c27d12d}.xpi .",
        "test": "vitest"
    },
    "eslintConfig": {
        "extends": [
            "react-app",
            "react-app/jest"
        ]
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "devDependencies": {
        "@vitejs/plugin-react": "^6.0.3",
        "happy-dom": "^20.10.6",
        "vite": "^8.1.3",
        "vitest": "^4.1.9"
    }
}
